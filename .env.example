# Base URL of the public guest API (the `/guest/*` prefix on the VPS).
# In local dev you can point this at a tunnel or staging host.
VITE_API_BASE_URL=https://api.example.com

# Which product this build is. The codebase ships to TWO Vercel projects that
# share this same repo + the same VITE_API_BASE_URL, but differ only here:
#   - non_targeted domain (fast emoji survey):   VITE_APP_MODE=non_targeted
#   - targeted domain (gamified, prize wheel):   VITE_APP_MODE=targeted
# Mode is a build-time constant — it is never a URL param, so the two domains
# can never cross over. Defaults to non_targeted when unset.
VITE_APP_MODE=non_targeted
